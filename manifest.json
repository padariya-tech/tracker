
{
  "manifest_version": 3,

  "name": "Dev Activity Tracker",

  "version": "1.0",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://leetcode.com/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}

